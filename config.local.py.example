    "provider": "kimi",
    "api_key": "sk-kimi-REPLACE_ME",
    "model": "kimi-k2-turbo-preview",
    # 仅 OpenRouter 用；Kimi 忽略此项
    "base_url": "https://supercodex.space/v1",
}

